---
/**
 * BaseLayout — root layout for every page.
 *
 * Provides:
 * - HTML head with meta + self-hosted fonts (Inter + JetBrains Mono via @fontsource) + favicon
 * - Pre-paint theme script (no flash of wrong theme)
 * - Schema.org JSON-LD per page (when provided)
 * - Skip-link, header (with theme toggle + per-page edit-on-GitHub link)
 * - Page grid: Sidebar | Main | MarginCol
 * - Footer with independence + Microsoft disclosure
 */
import Header from '@components/Header.astro';
import VendorTabs from '@components/VendorTabs.astro';
import CosmosBar from '@components/CosmosBar.astro';
import Sidebar from '@components/Sidebar.astro';
import MarginCol from '@components/MarginCol.astro';
import Footer from '@components/Footer.astro';
import SearchModal from '@components/SearchModal.astro';
import GlobalEnhance from '@components/GlobalEnhance.astro';
import MobileDrawer from '@components/MobileDrawer.astro';
import '@styles/global.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import '@fontsource/jetbrains-mono/600.css';

export interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  noIndex?: boolean;
  bodyClass?: string;
  entryFile?: string;
  lastUpdated?: string;
  schemaJsonLd?: string;
  margin?: { tocItems?: { id: string; text: string; level: number }[] };
}

const {
  title,
  description = "A practitioner's field notebook for AI tools you can run, wire, script, compare, or operationally reason about — Claude Code, Codex CLI, Gemini CLI, NotebookLM, Microsoft Copilot Studio + ATK, GitHub Copilot, OpenClaw, and the MCP servers that wire them together. By Sush.",
  canonical,
  ogImage,
  noIndex = false,
  bodyClass = '',
  entryFile,
  lastUpdated,
  schemaJsonLd,
  margin,
} = Astro.props;

// Word-boundary trim for SEO compliance (added 11 May 2026, Phase 3E sweep).
// Same pattern as the Plain AI / Agentic Planet sweeps — trim long titles and
// over-cap descriptions at the last whole word so SERPs stay clean.
const trimToWord = (s: string, max: number): string => {
  if (s.length <= max) return s;
  const sliced = s.slice(0, max);
  const lastSpace = sliced.lastIndexOf(' ');
  const cut = lastSpace > max * 0.6 ? sliced.slice(0, lastSpace) : sliced;
  return cut.replace(/[\s.,;:—–\-]+$/, '') + '…';
};

const hasBrand = title === 'Claw Planet' || title.includes('Claw Planet');
const rawTitle = hasBrand ? title : `${title} · Claw Planet`;
const fullTitle = trimToWord(rawTitle, 60);
const trimmedDescription = trimToWord(description, 155);

const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
---

<!DOCTYPE html>
<html lang="en">
<head>
  <!-- Apply saved/preferred theme BEFORE first paint to avoid flash -->
  <script is:inline>
    (function () {
      try {
        var saved = localStorage.getItem('cp-theme');
        var prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
        var theme = saved || (prefersDark ? 'dark' : 'light');
        if (theme === 'dark') document.documentElement.setAttribute('data-theme', 'dark');
      } catch (e) {}
    })();
  </script>

  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />

  <title>{fullTitle}</title>
  <meta name="description" content={trimmedDescription} />
  <link rel="canonical" href={canonicalUrl} />

  {noIndex && <meta name="robots" content="noindex, nofollow" />}

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Open Graph / social -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={trimmedDescription} />
  {ogImage && <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />}
  <meta property="og:site_name" content="Claw Planet" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={trimmedDescription} />
  {ogImage && <meta name="twitter:image" content={new URL(ogImage, Astro.site).toString()} />}

  <!-- RSS feed for /updates/ -->
  <link rel="alternate" type="application/rss+xml" title="Claw Planet — Updates" href="/updates/feed.xml" />

  {schemaJsonLd && <script type="application/ld+json" set:html={schemaJsonLd} />}
  <link rel="stylesheet" href="/cosmos-bar.css" />
  <link rel="stylesheet" href="/cosmos-footer.css" />

  {/* Cosmos GA4 — aggregate analytics for cosmos-wide intelligence (prod only).
      Single shared property G-2HWWZGWCD0 + event-scoped dim cosmos_planet.
      Ad signals denied; purely analytics_storage. Added 12 May 2026. */}
  {import.meta.env.PROD && (
    <>
      <script async src="https://www.googletagmanager.com/gtag/js?id=G-2HWWZGWCD0" is:inline></script>
      <script is:inline>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('consent','default',{ad_storage:'denied',ad_user_data:'denied',ad_personalization:'denied',analytics_storage:'granted'});
        gtag('js', new Date());
        gtag('config', 'G-2HWWZGWCD0', { cosmos_planet: 'claw', anonymize_ip: true });
      </script>
    </>
  )}
</head>

<body class={bodyClass}>
  <CosmosBar />
  <a href="#main" class="skip-link">Skip to main content</a>

  <Header entryFile={entryFile} lastUpdated={lastUpdated} />
  <VendorTabs />

  <div class="page">
    <Sidebar />
    <main id="main" class="main" tabindex="-1">
      <slot />
    </main>
    <MarginCol tocItems={margin?.tocItems} />
  </div>

  <Footer />

  <SearchModal />
  <MobileDrawer />
  <GlobalEnhance />

  <!-- Theme toggle binding (deferred — runs after DOM ready) -->
  <script is:inline>
    (function () {
      var btn = document.getElementById('themeToggle');
      if (!btn) return;
      btn.addEventListener('click', function () {
        var current = document.documentElement.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
        var next = current === 'dark' ? 'light' : 'dark';
        if (next === 'dark') {
          document.documentElement.setAttribute('data-theme', 'dark');
        } else {
          document.documentElement.removeAttribute('data-theme');
        }
        try { localStorage.setItem('cp-theme', next); } catch (e) {}
      });
    })();
  </script>
</body>
</html>
