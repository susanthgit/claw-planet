---
/**
 * BaseLayout — root layout for every page.
 *
 * Provides:
 * - HTML head with meta + Google Fonts + favicon
 * - Pre-paint theme script (no flash of wrong theme)
 * - Skip-link
 * - Header (with theme toggle)
 * - Page grid: Sidebar | Main | MarginCol
 * - Footer with independence + Microsoft disclosure
 */
import Header from '@components/Header.astro';
import Sidebar from '@components/Sidebar.astro';
import MarginCol from '@components/MarginCol.astro';
import Footer from '@components/Footer.astro';
import '@styles/global.css';

export interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  noIndex?: boolean;
  bodyClass?: string;
}

const {
  title,
  description = 'A plain-English study reference for the OpenClaw agent runtime. Concepts, setup paths, connections, plugins, security gotchas, and what is currently changing.',
  canonical,
  ogImage,
  noIndex = false,
  bodyClass = '',
} = Astro.props;

const fullTitle = title === 'Claw Planet'
  ? title
  : `${title} · Claw Planet`;

const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
---

<!DOCTYPE html>
<html lang="en">
<head>
  <!-- Apply saved/preferred theme BEFORE first paint to avoid flash -->
  <script is:inline>
    (function () {
      try {
        var saved = localStorage.getItem('cp-theme');
        var prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
        var theme = saved || (prefersDark ? 'dark' : 'light');
        if (theme === 'dark') document.documentElement.setAttribute('data-theme', 'dark');
      } catch (e) {}
    })();
  </script>

  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />

  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />

  {noIndex && <meta name="robots" content="noindex, nofollow" />}

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Google Fonts: Inter + JetBrains Mono -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />

  <!-- Open Graph / social -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  {ogImage && <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />}
  <meta property="og:site_name" content="Claw Planet" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  {ogImage && <meta name="twitter:image" content={new URL(ogImage, Astro.site).toString()} />}
</head>

<body class={bodyClass}>
  <a href="#main" class="skip-link">Skip to main content</a>

  <Header />

  <div class="page">
    <Sidebar />
    <main id="main" class="main" tabindex="-1">
      <slot />
    </main>
    <MarginCol />
  </div>

  <Footer />

  <!-- Theme toggle binding (deferred — runs after DOM ready) -->
  <script is:inline>
    (function () {
      var btn = document.getElementById('themeToggle');
      if (!btn) return;
      btn.addEventListener('click', function () {
        var current = document.documentElement.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
        var next = current === 'dark' ? 'light' : 'dark';
        if (next === 'dark') {
          document.documentElement.setAttribute('data-theme', 'dark');
        } else {
          document.documentElement.removeAttribute('data-theme');
        }
        try { localStorage.setItem('cp-theme', next); } catch (e) {}
      });
    })();
  </script>
</body>
</html>
