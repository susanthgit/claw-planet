---
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionHero from '@components/SectionHero.astro';
import CatalogTable from '@components/CatalogTable.astro';
import { getCollection } from 'astro:content';

const allUseCases = await getCollection('use-cases');
const useCaseEntries = allUseCases
  .filter(e => e.data.section === 'Use cases' && e.data.vendor === 'openclaw' && e.data.status === 'published')
  .sort((a, b) => a.data.sectionNumber.localeCompare(b.data.sectionNumber));

const catalogEntries = useCaseEntries.map(e => ({
  num: e.data.sectionNumber,
  title: e.data.title,
  href: `/openclaw/use-cases/${e.id.replace(/\.mdx?$/, '')}/`,
  description: e.data.description,
  state: e.data.verificationState,
  date: e.data.lastReviewedAt,
}));

const tested = useCaseEntries.filter(e => e.data.verificationState.startsWith('tested')).length;
const sourced = useCaseEntries.filter(e => e.data.verificationState === 'sourced').length;
const planned = useCaseEntries.filter(e => e.data.verificationState === 'planned').length;

const lede = `End-to-end recipes — concrete things to <em>build</em> with OpenClaw. Every recipe assumes <a href="/openclaw/use-cases/hello-world-laptop/">§5.1 hello-world</a> works (your baseline). They get progressively more ambitious from there: a Slack bot for a team, a WhatsApp FAQ answerer for a small business, a Pi-hosted always-on home agent, and a RAG agent over your personal docs. Each recipe declares its verification state — right now they're all <strong>sourced</strong> because Sush is just starting. Expect them to flip to <strong>tried</strong> as he runs them.`;
---

<BaseLayout
  title="§ 5 Use cases — what to build with OpenClaw"
  description="End-to-end recipes for building things with OpenClaw — hello-world, Slack-bot for a team, WhatsApp FAQ answerer, Pi-hosted home agent, RAG over personal docs."
>
  <SectionHero num="5" title="Use cases" lede={lede} tested={tested} sourced={sourced} planned={planned} />
  <CatalogTable entries={catalogEntries} />
</BaseLayout>

