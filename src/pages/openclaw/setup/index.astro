---
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionHero from '@components/SectionHero.astro';
import CatalogTable from '@components/CatalogTable.astro';
import { getCollection } from 'astro:content';

const allSetups = await getCollection('setups');
const setupEntries = allSetups
  .filter(e => e.data.section === 'Setup' && e.data.vendor === 'openclaw' && e.data.status === 'published')
  .sort((a, b) => a.data.sectionNumber.localeCompare(b.data.sectionNumber));

const catalogEntries = setupEntries.map(e => ({
  num: e.data.sectionNumber,
  title: e.data.title,
  href: `/openclaw/setup/${e.id.replace(/\.mdx?$/, '')}/`,
  description: e.data.description,
  state: e.data.verificationState,
  date: e.data.lastReviewedAt,
}));

const tested = setupEntries.filter(e => e.data.verificationState.startsWith('tested')).length;
const sourced = setupEntries.filter(e => e.data.verificationState === 'sourced').length;
const planned = setupEntries.filter(e => e.data.verificationState === 'planned').length;

const lede = `Five environments, one packaging method, one hardware matrix. Pick where OpenClaw will run — most people start on a laptop or a Pi 5. Every page has runnable commands you can paste, plus sanity-checks and the "what to do when it goes wrong" section we wished existed when learning. Each declares whether we've actually run it; right now everything's <strong>sourced</strong> because Sush hasn't run his first OpenClaw yet — pages flip to <strong>tested</strong> as he runs them.`;
---

<BaseLayout
  title="§ 2 Setup — install OpenClaw on any host"
  description="Install OpenClaw on a laptop, Linux server, Azure, Raspberry Pi, or Docker. Hardware matrix + concrete commands. Verification state declared on every page."
>
  <SectionHero num="2" title="Setup" lede={lede} tested={tested} sourced={sourced} planned={planned} />
  <CatalogTable entries={catalogEntries} />
</BaseLayout>

