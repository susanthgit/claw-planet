---
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionHero from '@components/SectionHero.astro';
import CatalogTable from '@components/CatalogTable.astro';
import { getCollection } from 'astro:content';

const allConnections = await getCollection('connections');
const connectionEntries = allConnections
  .filter(e => e.data.section === 'Connections' && e.data.status === 'published')
  .sort((a, b) => a.data.sectionNumber.localeCompare(b.data.sectionNumber));

const catalogEntries = connectionEntries.map(e => ({
  num: e.data.sectionNumber,
  title: e.data.title,
  href: `/openclaw/connections/${e.id.replace(/\.mdx?$/, '')}/`,
  description: e.data.description,
  state: e.data.verificationState,
  date: e.data.lastReviewedAt,
}));

const tested = connectionEntries.filter(e => e.data.verificationState.startsWith('tested')).length;
const sourced = connectionEntries.filter(e => e.data.verificationState === 'sourced').length;
const planned = connectionEntries.filter(e => e.data.verificationState === 'planned').length;

const lede = `The integration <em>patterns</em>, not the marketplace packages. <strong>Channels</strong> bring messages in and out (Slack, WhatsApp, Discord, etc.). <strong>Tools</strong> let the agent do work (browser, filesystem, web search, code exec). <strong>Models</strong> are the brains (Claude, GPT, local Ollama). <strong>Memory</strong> is what survives a restart (built-in, Honcho, QMD). For specific plugins/packages reviewed individually, see <a href="/openclaw/plugins/">§4 Plugins</a>.`;
---

<BaseLayout
  title="§ 3 Connections — channels, models, tools"
  description="Integration patterns for OpenClaw — channels, tools, models, memory. The categories that group what plugs in. §4 Plugins covers specific marketplace packages."
>
  <SectionHero num="3" title="Connections" lede={lede} tested={tested} sourced={sourced} planned={planned} />
  <CatalogTable entries={catalogEntries} />
</BaseLayout>

