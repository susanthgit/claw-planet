---
import BaseLayout from '@layouts/BaseLayout.astro';
import VendorHub from '@components/VendorHub.astro';

const vendor = {
  slug: 'openai',
  name: 'OpenAI',
  blurb: 'GPT, the model family — plus the developer surfaces that wrap it: Codex CLI (terminal coding agent), the OpenAI Agents SDK (Python / TypeScript framework for multi-agent systems with handoffs and tracing), the OpenAI Apps SDK (MCP plugins that render rich widgets inside ChatGPT), ChatGPT Atlas (the new browser), and Custom GPTs (no-code chat assistants). Sush hasn\'t standalone-run any of these — they\'re on the learning roadmap.',
  officialUrl: 'https://platform.openai.com/docs',
  officialLabel: 'platform.openai.com/docs',
  status: 'coming-in-batch' as const,
  statusNote: 'Day-1 sourced seed shipping in Batch B (~20 pages: Codex CLI · Agents SDK · Apps SDK · ChatGPT Atlas · Custom GPTs).',
};

const products = [
  { slug: 'codex-cli', name: 'Codex CLI', type: 'CLI' as const, status: 'coming-in-batch' as const, batchHint: 'Batch B', description: 'OpenAI\'s terminal coding agent — installs via npm, reads your repo, runs in a sandbox, edits files. The closest analogue to Claude Code from the OpenAI side. MCP integration on the roadmap.' },
  { slug: 'agents-sdk', name: 'OpenAI Agents SDK', type: 'API / SDK' as const, status: 'coming-in-batch' as const, batchHint: 'Batch B', description: 'Python + TypeScript framework for building agents — handoffs between agents, tool calls, tracing, guardrails. The successor / sibling to the Assistants API.' },
  { slug: 'apps-sdk', name: 'OpenAI Apps SDK', type: 'API / SDK' as const, status: 'coming-in-batch' as const, batchHint: 'Batch B', description: 'MCP plugins that render rich widgets inside ChatGPT. Uses the `text/html+skybridge` content type for client-side widget rendering. The cross-vendor MCP overlap is the interesting bit.' },
  { slug: 'chatgpt-atlas', name: 'ChatGPT Atlas', type: 'Hosted product' as const, status: 'coming-in-batch' as const, batchHint: 'Batch B', description: 'OpenAI\'s new browser — built around an embedded ChatGPT that reads what you\'re looking at. Dossier on what it does well, what it doesn\'t, privacy implications.' },
  { slug: 'custom-gpts', name: 'Custom GPTs', type: 'Hosted product' as const, status: 'coming-in-batch' as const, batchHint: 'Batch B', description: 'No-code chat assistants you build with instructions + knowledge files + actions. Useful for narrow internal use cases. The GPT Store is the marketplace.' },
];
---

<BaseLayout
  title="OpenAI — Claw"
  description="OpenAI vendor hub on Claw — plain-English field notes on Codex CLI, the OpenAI Agents SDK, Apps SDK, ChatGPT Atlas browser, and Custom GPTs. Day-1 sourced seed shipping in Batch B."
  ogImage="/og/home.png"
>
  <VendorHub vendor={vendor} products={products} />
</BaseLayout>
