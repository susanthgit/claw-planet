---
import BaseLayout from '@layouts/BaseLayout.astro';
import VendorHub from '@components/VendorHub.astro';
import { getCollection } from 'astro:content';

// Count Microsoft entries per product (Batch D, 15 May 2026).
async function countByProduct(productKey: string): Promise<number> {
  const collections = ['explainers', 'setups', 'use-cases', 'gotchas'];
  let n = 0;
  for (const col of collections) {
    const entries = await getCollection(col as any);
    for (const e of entries as any[]) {
      if (e.data.vendor === 'microsoft' && e.data.product === productKey && e.data.status === 'published') {
        n++;
      }
    }
  }
  return n;
}

const atkCount = await countByProduct('agents-toolkit');
const cpsCount = await countByProduct('copilot-studio');
const fdyCount = await countByProduct('foundry');
const ghcCount = await countByProduct('github-copilot');
const daCount  = await countByProduct('declarative-agents');
const mcpCount = await countByProduct('mcp');
const vscCount = await countByProduct('vs-code');
const total = atkCount + cpsCount + fdyCount + ghcCount + daCount + mcpCount + vscCount;

const vendor = {
  slug: 'microsoft',
  name: 'Microsoft',
  blurb: `Microsoft's builder-shaped AI surfaces — the <strong>Microsoft 365 Agents Toolkit</strong> (the VS Code + CLI scaffolder for declarative agents, API plugins, and MCP plugins), <strong>Copilot Studio</strong> (the low-code agent builder), <strong>Microsoft Foundry</strong> (formerly Azure AI Foundry — the managed model + agent platform; URL path still says <code>/azure/ai-foundry/</code>), <strong>GitHub Copilot</strong> (the IDE + Chat + CLI coding assistant — model picker now spans Claude, GPT, and Gemini), <strong>Declarative Agents</strong> (the manifest-based agent format that runs inside M365 Copilot Chat), and <strong>MCP support across Microsoft surfaces</strong> (VS Code, Copilot Studio, ATK, Foundry — what's GA, what's preview). <em>Sush's day-job slice</em> — he's a Copilot Solution Engineer at Microsoft NZ. <strong>Everything below is sourced from public Microsoft docs, GitHub, and devblogs. No customer engagement detail. Ever.</strong>`,
  officialUrl: 'https://learn.microsoft.com',
  officialLabel: 'learn.microsoft.com',
  status: total >= 8 ? 'live' as const : 'coming-in-batch' as const,
  statusNote: total >= 8
    ? `Batch D shipped — ${total} sourced entries live across 7 products. Pages all start as <em>sourced</em> with citations; Sush upgrades to <em>tried</em> over time as he experiments. PRs with verification notes welcome.`
    : `Day-1 sourced seed is mid-build (Batch D — ${total}/8 pages so far). Pages all start as <em>sourced</em> with citations.`,
};

const products = [
  { slug: 'agents-toolkit', name: 'M365 Agents Toolkit (ATK)', type: 'CLI' as const, status: (atkCount > 0 ? 'live' : 'coming-in-batch') as 'live' | 'coming-in-batch', batchHint: 'Batch D', href: '/microsoft/agents-toolkit/', description: `VS Code extension + CLI (formerly Teams Toolkit) for scaffolding declarative agents, API plugins, and MCP plugins for Microsoft 365 Copilot. Free and open-source. ${atkCount} pages: overview · scaffolding a declarative agent.` },
  { slug: 'copilot-studio', name: 'Copilot Studio', type: 'Low-code platform' as const, status: (cpsCount > 0 ? 'live' : 'coming-in-batch') as 'live' | 'coming-in-batch', batchHint: 'Batch D', href: '/microsoft/copilot-studio/', description: `Microsoft's low-code agent builder — drag-and-drop topics, attach knowledge sources, wire in connectors, publish to Teams / web / M365 Copilot. Per-message PAYG and tenant licensing options. ${cpsCount} pages: overview · making a custom copilot.` },
  { slug: 'foundry', name: 'Microsoft Foundry', type: 'API / SDK' as const, status: (fdyCount > 0 ? 'live' : 'coming-in-batch') as 'live' | 'coming-in-batch', batchHint: 'Batch D', href: '/microsoft/foundry/', description: `Microsoft's managed model + agent platform on Azure (formerly Azure AI Foundry; the "Azure AI" prefix dropped during 2025). Model catalogue (1,900+), Foundry Agent Service, evaluations, observability. Entra-based auth. ${fdyCount} pages: overview.` },
  { slug: 'github-copilot', name: 'GitHub Copilot', type: 'CLI' as const, status: (ghcCount > 0 ? 'live' : 'coming-in-batch') as 'live' | 'coming-in-batch', batchHint: 'Batch D', href: '/microsoft/github-copilot/', description: `GitHub's developer assistant — code completion + Chat + CLI. Surfaces in VS Code, JetBrains, Visual Studio, Xcode, Neovim, Eclipse, terminal. Free / Pro / Pro+ / Business / Enterprise tiers. ${ghcCount} pages: overview.` },
  { slug: 'declarative-agents', name: 'Declarative Agents (M365)', type: 'API / SDK' as const, status: (daCount > 0 ? 'live' : 'coming-in-batch') as 'live' | 'coming-in-batch', batchHint: 'Batch D', href: '/microsoft/declarative-agents/', description: `The manifest-based agent format that runs inside Microsoft 365 Copilot Chat. Conversation starters, instructions, capabilities (web search, Graph connectors, code interpreter, OneDrive/SharePoint), API-plugin actions. ${daCount} pages: overview.` },
  { slug: 'mcp', name: 'MCP for Microsoft surfaces', type: 'Catalogue' as const, status: (mcpCount > 0 ? 'live' : 'coming-in-batch') as 'live' | 'coming-in-batch', batchHint: 'Batch D', href: '/microsoft/mcp/', description: `Where MCP plugs into the Microsoft AI stack: VS Code (agent mode), GitHub Copilot, Copilot Studio (actions), the M365 Agents Toolkit, and Foundry Agent Service. Status differs per surface. ${mcpCount} pages: overview.` },
  { slug: 'vs-code', name: 'VS Code (as an MCP host)', type: 'IDE' as const, status: (vscCount > 0 ? 'live' : 'coming-in-batch') as 'live' | 'coming-in-batch', batchHint: 'Batch E', href: '/microsoft/vs-code/', description: `Microsoft's editor MCP host — runs MCP servers via the GitHub Copilot extension in agent mode. Per-workspace <code>.vscode/mcp.json</code> makes team-shared config straightforward. Tools GA since v1.99 (Mar 2025); full client maturity (Resources + Prompts + Auth) GA v1.101 (May 2025). Sandboxing macOS + Linux only — Windows always unsandboxed. ${vscCount} pages: overview.` },
];
---

<BaseLayout
  title="Microsoft — Claw"
  description="Microsoft vendor hub on Claw — builder-only, public-sourced-only field notes on M365 Agents Toolkit, Copilot Studio, Microsoft Foundry, GitHub Copilot, Declarative Agents, MCP for Microsoft surfaces, and VS Code as an MCP host. No customer engagement detail."
  ogImage="/og/home.png"
>
  <VendorHub vendor={vendor} products={products} compareLinks={[
    { href: '/compare/cli-coding-agents/', label: '§ 7.2', title: 'CLI coding agents (Claude Code vs Codex CLI vs Gemini CLI vs Copilot CLI)' },
    { href: '/compare/m365-extensibility-paths/', label: '§ 7.3', title: 'M365 extensibility paths (Copilot Studio vs Declarative Agents vs Custom Engine Agents)' },
    { href: '/compare/direct-model-apis/', label: '§ 7.4', title: 'Direct model APIs — Foundry (Azure-governed platform, vs Claude API vs Gemini API)' },
    { href: '/compare/hosted-agent-platforms/', label: '§ 7.5', title: 'Agent platforms — Foundry Agent Service vs Vertex AI Agents vs OpenAI Agents SDK vs Copilot Studio' },
    { href: '/compare/mcp-clients/', label: '§ 7.6', title: 'MCP hosts and clients — where you plug an MCP server in (Claude Desktop · Claude Code · VS Code · Cursor · Copilot Studio · Copilot CLI · Foundry Agent Service · GHC cloud agent)' },
  ]} />
</BaseLayout>

