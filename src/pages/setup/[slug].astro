---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const all = await getCollection('setups');
  return all
    .filter(e => e.data.section === 'Setup' && e.data.status === 'published')
    .map(entry => ({
      params: { slug: entry.id.replace(/\.mdx?$/, '') },
      props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const stateLabels: Record<string, string> = {
  'tested-by-sush': '● TESTED BY US',
  'tested-by-contributor': '● TESTED BY CONTRIBUTOR',
  'sourced-only': '● SOURCED ONLY',
  'planned': '● PLANNED',
};
const stateClassMap: Record<string, string> = {
  'tested-by-sush': 'verif-t',
  'tested-by-contributor': 'verif-t',
  'sourced-only': 'verif-s',
  'planned': 'verif-e',
};
const stateLabel = stateLabels[entry.data.verificationState] ?? '';
const stateClass = stateClassMap[entry.data.verificationState] ?? '';
---

<BaseLayout
  title={`§ ${entry.data.sectionNumber} ${entry.data.title}`}
  description={entry.data.description}
>
  <article class="entry-page">
    <header class="entry-header">
      <div class="crumb">
        <a href="/setup/">§ 2 Setup</a>
        <span>/</span>
        <span class="num">§ {entry.data.sectionNumber}</span>
      </div>
      <h1>{entry.data.title}</h1>
      <p class="lede">{entry.data.description}</p>
      <div class="entry-meta">
        <span class={`verif ${stateClass}`}>{stateLabel}</span>
        <span class="meta-stat">last reviewed <strong>{entry.data.lastReviewedAt}</strong></span>
        {entry.data.lastTestedAt && <span class="meta-stat">last tested <strong>{entry.data.lastTestedAt}</strong></span>}
        {entry.data.estimatedTimeMinutes && <span class="meta-stat">est. <strong>{entry.data.estimatedTimeMinutes} min</strong></span>}
        {entry.data.runtimeVersion && <span class="meta-stat">runtime: <strong>{entry.data.runtimeVersion}</strong></span>}
      </div>
      {entry.data.verificationNote && (
        <div class="verif-note">
          <strong>Note on verification:</strong> {entry.data.verificationNote}
        </div>
      )}
    </header>

    <div class="prose">
      <Content />
    </div>

    {entry.data.sources && entry.data.sources.length > 0 && (
      <section class="sources">
        <h3>Sources</h3>
        <ul>
          {entry.data.sources.map(src => (
            <li><a href={src} target="_blank" rel="noopener">{src}</a></li>
          ))}
        </ul>
      </section>
    )}

    <footer class="entry-foot">
      <a href={`https://github.com/susanthgit/claw-planet/edit/main/src/content/setups/${entry.id}`} target="_blank" rel="noopener">edit this page on GitHub →</a>
      <a href="https://github.com/susanthgit/claw-planet/issues/new" target="_blank" rel="noopener">dispute or correct →</a>
    </footer>
  </article>
</BaseLayout>

<style>
  .entry-page { max-width: 760px; }

  .entry-header {
    border-bottom: 1px solid var(--rule);
    padding-bottom: 28px;
    margin-bottom: 32px;
  }
  .crumb {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--ink-faint);
    margin-bottom: 16px;
    display: flex;
    gap: 8px;
    align-items: center;
    letter-spacing: var(--ls-wide);
  }
  .crumb a { color: var(--ink-mute); text-decoration: none; }
  .crumb a:hover { color: var(--claw); }
  .crumb .num { color: var(--claw); font-weight: 600; }

  .entry-page h1 {
    font-size: 36px;
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.1;
    color: var(--ink);
    margin-bottom: 12px;
  }
  .lede {
    font-size: 17px;
    color: var(--ink-mid);
    line-height: 1.55;
    max-width: 640px;
    margin-bottom: 18px;
  }
  .entry-meta {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--ink-mute);
  }
  .meta-stat strong { color: var(--ink); font-weight: 600; }

  .verif {
    padding: 3px 10px;
    border-radius: var(--radius-pill);
    border-width: 1px;
    border-style: solid;
    letter-spacing: var(--ls-wide);
    font-weight: 600;
  }
  .verif.verif-t { color: var(--olive); border-color: var(--olive); background: var(--olive-soft); }
  .verif.verif-s { color: var(--amber); border-color: var(--amber); background: var(--amber-soft); }
  .verif.verif-e { color: var(--claw); border-color: var(--claw); background: var(--claw-tint); }

  .verif-note {
    margin-top: 18px;
    padding: 12px 16px;
    border-left: 3px solid var(--amber);
    background: var(--amber-soft);
    font-size: 13.5px;
    color: var(--ink-mid);
    line-height: 1.55;
  }
  .verif-note strong { color: var(--ink); font-weight: 600; }

  .prose :global(h2) {
    font-size: 24px; font-weight: 700;
    letter-spacing: -0.015em;
    margin: 36px 0 12px;
    color: var(--ink);
    padding-bottom: 6px;
    border-bottom: 1px solid var(--rule-faint);
  }
  .prose :global(h3) {
    font-size: 18px; font-weight: 700;
    letter-spacing: -0.01em;
    margin: 28px 0 8px;
    color: var(--ink);
  }
  .prose :global(h4) {
    font-size: 15px; font-weight: 700;
    margin: 20px 0 6px;
    color: var(--ink);
  }
  .prose :global(p) { margin: 12px 0; line-height: var(--lh-normal); color: var(--ink); }
  .prose :global(ul), .prose :global(ol) { margin: 12px 0 12px 24px; line-height: var(--lh-normal); }
  .prose :global(li) { margin: 4px 0; color: var(--ink); }
  .prose :global(strong) { color: var(--ink); font-weight: 700; }
  .prose :global(em) { color: var(--ink-mid); }
  .prose :global(a) {
    color: var(--ink); text-decoration: underline;
    text-decoration-color: var(--rule); text-underline-offset: 2px;
  }
  .prose :global(a:hover) { color: var(--claw); text-decoration-color: var(--claw); }

  .prose :global(blockquote) {
    margin: 18px 0; padding: 12px 18px;
    border-left: 3px solid var(--claw);
    background: var(--claw-tint);
    font-style: italic; color: var(--ink-mid);
  }
  .prose :global(blockquote p) { margin: 4px 0; }

  .prose :global(code) {
    font-family: var(--mono); font-size: 13px;
    background: var(--paper-warm); padding: 1px 6px;
    border-radius: 3px; color: var(--ink);
  }
  .prose :global(pre) {
    font-family: var(--mono); font-size: 12.5px;
    background: var(--canvas);
    border: 1px solid var(--rule-faint);
    padding: 14px 18px; overflow-x: auto;
    line-height: 1.5; margin: 16px 0;
  }
  .prose :global(pre code) { background: transparent; padding: 0; }

  .prose :global(table) {
    margin: 18px 0; border-collapse: collapse;
    font-size: 13.5px; width: 100%;
  }
  .prose :global(thead) { border-bottom: 2px solid var(--rule); }
  .prose :global(th) {
    text-align: left; padding: 8px 12px;
    font-weight: 600; color: var(--ink);
  }
  .prose :global(td) {
    padding: 8px 12px;
    border-bottom: 1px solid var(--rule-faint);
    color: var(--ink-mid); line-height: 1.5;
    vertical-align: top;
  }

  .sources {
    margin-top: 36px; padding-top: 22px;
    border-top: 1px solid var(--rule-faint);
  }
  .sources h3 {
    font-family: var(--mono); font-size: 10.5px;
    letter-spacing: var(--ls-widest); text-transform: uppercase;
    color: var(--ink-faint); margin-bottom: 10px;
    font-weight: 700;
  }
  .sources ul { list-style: none; margin: 0; padding: 0; }
  .sources li { padding: 4px 0; font-size: 13px; }
  .sources a {
    color: var(--ink-mid); font-family: var(--mono);
    font-size: 12.5px; word-break: break-all;
    text-decoration: none;
    border-bottom: 1px solid var(--rule);
    padding-bottom: 1px;
  }
  .sources a:hover { color: var(--claw); border-color: var(--claw); }

  .entry-foot {
    margin-top: 36px; padding-top: 16px;
    border-top: 1px solid var(--rule-faint);
    display: flex; justify-content: space-between;
    font-family: var(--mono); font-size: 11px;
    flex-wrap: wrap; gap: 12px;
  }
  .entry-foot a { color: var(--ink-mute); text-decoration: none; }
  .entry-foot a:hover { color: var(--claw); }
</style>
