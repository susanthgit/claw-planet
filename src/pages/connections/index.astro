---
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionHead from '@components/SectionHead.astro';
import SectionBlurb from '@components/SectionBlurb.astro';
import CatalogTable from '@components/CatalogTable.astro';
import { getCollection } from 'astro:content';

const allConnections = await getCollection('connections');
const connectionEntries = allConnections
  .filter(e => e.data.section === 'Connections' && e.data.status === 'published')
  .sort((a, b) => a.data.sectionNumber.localeCompare(b.data.sectionNumber));

const catalogEntries = connectionEntries.map(e => ({
  num: e.data.sectionNumber,
  title: e.data.title,
  href: `/connections/${e.id.replace(/\.mdx?$/, '')}/`,
  description: e.data.description,
  state: e.data.verificationState,
  date: e.data.lastReviewedAt,
}));

const verbCount = `${connectionEntries.length} entries · all sourced`;
---

<BaseLayout
  title="§ 3 Connections"
  description="Integration patterns for OpenClaw — channels, tools, models, memory. The categories that group what plugs in. §4 Plugins covers specific marketplace packages."
  noIndex={true}
>
  <SectionHead num="3" title="Connections" verb={verbCount} />
  <SectionBlurb>
    The integration <em>patterns</em>, not the marketplace packages. <strong>Channels</strong> bring
    messages in and out (Slack, WhatsApp, Discord, etc.). <strong>Tools</strong> let the agent do
    work (browser, filesystem, web search, code exec). <strong>Models</strong> are the brains (Claude,
    GPT, local Ollama). <strong>Memory</strong> is what survives a restart (built-in, Honcho, QMD).
    For specific plugins/packages reviewed individually, see <a href="/plugins/">§4 Plugins</a>.
  </SectionBlurb>
  <CatalogTable entries={catalogEntries} />
</BaseLayout>
