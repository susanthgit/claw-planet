---
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionHead from '@components/SectionHead.astro';
import SectionBlurb from '@components/SectionBlurb.astro';
import UpdateRow from '@components/UpdateRow.astro';
import { updates } from '@data/updates';

const latestDate = updates.length > 0
  ? updates.reduce((max, u) => (u.date > max ? u.date : max), updates[0].date)
  : '—';
---

<BaseLayout
  title="§ 8 Updates — OpenClaw release watchlist"
  description="Hand-curated watchlist of OpenClaw + agent-runtime news. Releases, advisories, community moves. Not a CVE feed; high-signal items only."
>
  <SectionHead num="8" title="Updates we're watching" verb={`${updates.length} entries · curated weekly`} />
  <SectionBlurb>
    Hand-curated. <strong>Not a CVE feed</strong> and not a release tracker. High-signal items only —
    things that change how you would run OpenClaw, what you would build, or what to be aware of.
    Each item has a date, type, and source link. Last updated <strong>{latestDate}</strong>.
  </SectionBlurb>

  <div class="updates-list">
    {updates.map(u => <UpdateRow {...u} />)}
  </div>

  <div class="cross-refs">
    <strong>also:</strong>
    <a href="https://github.com/susanthgit/claw-planet">repo</a>
    <a href="https://discord.gg/clawd">OpenClaw Discord</a>
    <a href="/openclaw/resources/">curated external sources</a>
  </div>
</BaseLayout>

<style>
  .updates-list { border-top: 1px solid var(--rule-faint); margin-top: 16px; }
</style>
