---
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionHead from '@components/SectionHead.astro';
import SectionBlurb from '@components/SectionBlurb.astro';
import CatalogTable from '@components/CatalogTable.astro';
import { getCollection } from 'astro:content';

const allUseCases = await getCollection('use-cases');
const useCaseEntries = allUseCases
  .filter(e => e.data.section === 'Use cases' && e.data.status === 'published')
  .sort((a, b) => a.data.sectionNumber.localeCompare(b.data.sectionNumber));

const catalogEntries = useCaseEntries.map(e => ({
  num: e.data.sectionNumber,
  title: e.data.title,
  href: `/use-cases/${e.id.replace(/\.mdx?$/, '')}/`,
  description: e.data.description,
  state: e.data.verificationState,
  date: e.data.lastReviewedAt,
}));

const verbCount = `${useCaseEntries.length} recipes · all sourced`;
---

<BaseLayout
  title="§ 5 Use cases"
  description="End-to-end recipes for building things with OpenClaw — hello-world, Slack-bot for a team, WhatsApp FAQ answerer, Pi-hosted home agent, RAG over personal docs."
  noIndex={true}
>
  <SectionHead num="5" title="Use cases" verb={verbCount} />
  <SectionBlurb>
    End-to-end recipes — concrete things to <em>build</em> with OpenClaw. Every recipe assumes
    <a href="/use-cases/hello-world-laptop/">§5.1 hello-world</a> works (your baseline). They get
    progressively more ambitious from there: a Slack bot for a team, a WhatsApp FAQ answerer for a
    small business, a Pi-hosted always-on home agent, and a RAG agent over your personal docs.
    Each recipe declares its verification state — right now they're all <strong>sourced-only</strong>
    because Sush is just starting. Expect them to flip to <strong>tested-by-sush</strong> as he
    runs them.
  </SectionBlurb>
  <CatalogTable entries={catalogEntries} />
</BaseLayout>
