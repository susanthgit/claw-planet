---
import BaseLayout from '@layouts/BaseLayout.astro';
import Banner from '@components/Banner.astro';
import SectionHead from '@components/SectionHead.astro';
import SectionBlurb from '@components/SectionBlurb.astro';
import InlineFig from '@components/InlineFig.astro';
import CatalogTable from '@components/CatalogTable.astro';
import UpdateRow from '@components/UpdateRow.astro';
import { getCollection } from 'astro:content';

const explainers = (await getCollection('explainers'))
  .filter((e: any) => e.data.section === 'Overview' && e.data.status === 'published')
  .sort((a: any, b: any) => a.data.sectionNumber.localeCompare(b.data.sectionNumber));

const setups = (await getCollection('setups'))
  .filter((e: any) => e.data.section === 'Setup' && e.data.status === 'published')
  .sort((a: any, b: any) => a.data.sectionNumber.localeCompare(b.data.sectionNumber));

const connections = (await getCollection('connections'))
  .filter((e: any) => e.data.section === 'Connections' && e.data.status === 'published')
  .sort((a: any, b: any) => a.data.sectionNumber.localeCompare(b.data.sectionNumber));

const plugins = (await getCollection('plugins'))
  .filter((e: any) => e.data.section === 'Plugins' && e.data.status === 'published')
  .sort((a: any, b: any) => a.data.sectionNumber.localeCompare(b.data.sectionNumber));

const useCases = (await getCollection('use-cases'))
  .filter((e: any) => e.data.section === 'Use cases' && e.data.status === 'published')
  .sort((a: any, b: any) => a.data.sectionNumber.localeCompare(b.data.sectionNumber));

const gotchas = (await getCollection('gotchas'))
  .filter((e: any) => e.data.section === 'Security' && e.data.status === 'published')
  .sort((a: any, b: any) => a.data.sectionNumber.localeCompare(b.data.sectionNumber));

const compares = (await getCollection('compares'))
  .filter((e: any) => e.data.section === 'Compare' && e.data.status === 'published')
  .sort((a: any, b: any) => a.data.sectionNumber.localeCompare(b.data.sectionNumber));

function toCatalog(entries: any[], baseHref: string) {
  return entries.map(e => ({
    num: e.data.sectionNumber,
    title: e.data.title,
    href: `${baseHref}/${e.id.replace(/\.mdx?$/, '')}/`,
    description: e.data.description,
    state: e.data.verificationState,
    date: e.data.lastReviewedAt,
  }));
}

const overviewCatalog = toCatalog(explainers, '/overview');
const setupCatalog = toCatalog(setups, '/setup');
const connectionsCatalog = toCatalog(connections, '/connections');
const pluginsCatalog = toCatalog(plugins, '/plugins');
const useCasesCatalog = toCatalog(useCases, '/use-cases');
const securityCatalog = toCatalog(gotchas, '/security');
const compareCatalog = toCatalog(compares, '/compare');

const updates = [
  {
    date: '2026-05-07',
    tag: 'NEWS' as const,
    title: 'Claw Planet goes live',
    href: '/',
    meta: 'Soft launch with §1–§7 substantive content. All entries sourced-only until Sush actually runs OpenClaw end-to-end.',
  },
  {
    date: '2026-05-07',
    tag: 'NEWS' as const,
    title: 'Sourced OpenClaw primitive map (46 primitives) shipped',
    href: 'https://github.com/susanthgit/claw-planet/blob/main/src/data/openclaw-primitives.json',
    meta: 'Every concept page is grounded in this map. Workspace files, channels, tools, models, memory, security, automation — all with real source URLs.',
  },
];
---

<BaseLayout
  title="Claw Planet"
  description="A plain-English study reference for the OpenClaw agent runtime. Concepts, setup paths, connections, plugin field notes, use-case recipes, security gotchas, comparisons. Independent guide by Sush — sourced where we have not run it ourselves yet."
>
  <Banner />

  <SectionHead num="1" title="Overview" verb={`${overviewCatalog.length} entries · all sourced`} />
  <SectionBlurb>
    Start here if OpenClaw is new to you. Five-minute orientation, the seven canonical workspace
    files, a flat schematic of the runtime, and the drawbacks the official docs won't lead with.
  </SectionBlurb>
  <InlineFig caption="FIG. 1 · OpenClaw runtime — high-level flow" />
  <CatalogTable entries={overviewCatalog} />
  <a href="/overview/" class="open-section-link">→ open § 1 Overview</a>

  <SectionHead num="2" title="Setup" verb={`${setupCatalog.length} entries · all sourced`} />
  <SectionBlurb>
    Six install paths from laptop to Pi to Azure, plus a hardware matrix. Concrete commands. Sush
    will run his first setup soon and pages will flip to <strong>tested-by-sush</strong> as he does.
  </SectionBlurb>
  <CatalogTable entries={setupCatalog} />
  <a href="/setup/" class="open-section-link">→ open § 2 Setup</a>

  <SectionHead num="3" title="Connections" verb={`${connectionsCatalog.length} entries · all sourced`} />
  <SectionBlurb>
    Integration <em>patterns</em>: channels (24+ messaging surfaces), tools (built-ins + skills + MCP),
    models (Claude / GPT / Gemini / local), memory (built-in / Honcho / QMD). For specific marketplace
    packages reviewed individually, see <a href="/plugins/">§ 4</a>.
  </SectionBlurb>
  <CatalogTable entries={connectionsCatalog} />
  <a href="/connections/" class="open-section-link">→ open § 3 Connections</a>

  <SectionHead num="4" title="Plugins" verb={`${pluginsCatalog.length} field note${pluginsCatalog.length === 1 ? '' : 's'} · sourced`} />
  <SectionBlurb>
    Independent <strong>field notes</strong>, not formal scorecards. Each declares what we checked,
    what we didn't, sources used, and a dispute link. More to come as Sush samples plugins.
  </SectionBlurb>
  <CatalogTable entries={pluginsCatalog} />
  <a href="/plugins/" class="open-section-link">→ open § 4 Plugins</a>

  <SectionHead num="5" title="Use cases" verb={`${useCasesCatalog.length} recipes · sourced`} />
  <SectionBlurb>
    End-to-end recipes — the things to actually build. Hello-world, Slack agent, WhatsApp FAQ, Pi
    home agent, RAG over personal docs. Each recipe pairs with at least one setup page.
  </SectionBlurb>
  <CatalogTable entries={useCasesCatalog} />
  <a href="/use-cases/" class="open-section-link">→ open § 5 Use cases</a>

  <SectionHead num="6" title="Security" verb={`${securityCatalog.length} entries · all published`} />
  <SectionBlurb>
    Not a CVE tracker. Patterns to actually do (and not do) when self-hosting an agent runtime.
    Self-hosting checklist, plugin trust signals, common failure shapes, and what NOT to build.
  </SectionBlurb>
  <CatalogTable entries={securityCatalog} />
  <a href="/security/" class="open-section-link">→ open § 6 Security</a>

  <SectionHead num="7" title="Compare" verb={`${compareCatalog.length} matchup${compareCatalog.length === 1 ? '' : 's'}`} />
  <SectionBlurb>
    OpenClaw vs the alternatives. Currently one deep matchup live (vs MCP-based stacks); more land
    as Sush gains direct comparison experience.
  </SectionBlurb>
  <CatalogTable entries={compareCatalog} />
  <a href="/compare/" class="open-section-link">→ open § 7 Compare</a>

  <SectionHead num="8" title="Updates we're watching" verb={`${updates.length} recent · curated`} />
  <SectionBlurb>
    Hand-curated. <strong>Not a CVE feed.</strong> Each item carries a date, type, and source link.
  </SectionBlurb>
  <div>
    {updates.map(u => <UpdateRow {...u} />)}
  </div>
  <a href="/updates/" class="open-section-link">→ open § 8 Updates</a>

  <SectionHead num="9" title="Resources" verb="curated external · linked, not duplicated" />
  <SectionBlurb>
    The good stuff written elsewhere. Official OpenClaw docs, community spaces, MCP context, reading
    on agent design.
  </SectionBlurb>
  <a href="/resources/" class="open-section-link">→ open § 9 Resources</a>

  <SectionHead num="10" title="FAQ" verb="real questions Sush had" />
  <SectionBlurb>
    Eight entries — production readiness, vs MCP stacks, cost, Pi 4 viability, hijacking defence,
    docs comparison, longevity, the bracket-asterisk logo.
  </SectionBlurb>
  <a href="/faq/" class="open-section-link">→ open § 10 FAQ</a>
</BaseLayout>

<style>
.open-section-link {
  display: inline-block;
  margin-top: var(--space-3);
  margin-bottom: var(--space-6);
  font-family: var(--font-mono);
  font-size: 13px;
  color: var(--accent);
  text-decoration: none;
  border-bottom: 1px dashed var(--accent);
  padding-bottom: 1px;
}
.open-section-link:hover {
  border-bottom-style: solid;
}
</style>
