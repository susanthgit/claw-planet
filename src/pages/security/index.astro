---
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionHead from '@components/SectionHead.astro';
import SectionBlurb from '@components/SectionBlurb.astro';
import CatalogTable from '@components/CatalogTable.astro';
import { getCollection } from 'astro:content';

const allGotchas = await getCollection('gotchas');
const securityEntries = allGotchas
  .filter(e => e.data.section === 'Security' && e.data.status === 'published')
  .sort((a, b) => a.data.sectionNumber.localeCompare(b.data.sectionNumber));

const catalogEntries = securityEntries.map(e => ({
  num: e.data.sectionNumber,
  title: e.data.title,
  href: `/security/${e.id.replace(/\.mdx?$/, '')}/`,
  description: e.data.description,
  state: e.data.verificationState,
  date: e.data.lastReviewedAt,
}));

const verbCount = `${securityEntries.length} entries · all sourced`;
---

<BaseLayout
  title="§ 6 Security"
  description="High-level practical security patterns for self-hosted OpenClaw — checklist, plugin trust, common patterns, and what NOT to build as an agent."
  noIndex={true}
>
  <SectionHead num="6" title="Security" verb={verbCount} />
  <SectionBlurb>
    Not a CVE tracker. <strong>The patterns to actually do</strong> (and not do) when self-hosting an
    agent runtime with a third-party plugin marketplace. The 12-item checklist hardens your install,
    the trust-signals page tells you what to look for in plugins, the practical-patterns page covers
    the eight failure modes you'll meet, and the "what NOT to build" page is the counter-intuitive
    list of jobs better served by simpler tools.
  </SectionBlurb>
  <CatalogTable entries={catalogEntries} />
</BaseLayout>
