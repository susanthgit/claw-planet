---
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionHead from '@components/SectionHead.astro';
import SectionBlurb from '@components/SectionBlurb.astro';
import CatalogTable from '@components/CatalogTable.astro';
import { getCollection } from 'astro:content';

const allPlugins = await getCollection('plugins');
const pluginEntries = allPlugins
  .filter(e => e.data.section === 'Plugins' && e.data.status === 'published')
  .sort((a, b) => a.data.sectionNumber.localeCompare(b.data.sectionNumber));

const catalogEntries = pluginEntries.map(e => ({
  num: e.data.sectionNumber,
  title: e.data.title,
  href: `/plugins/${e.id.replace(/\.mdx?$/, '')}/`,
  description: e.data.description,
  state: e.data.verificationState,
  date: e.data.lastReviewedAt,
}));

const verbCount = `${pluginEntries.length} field note${pluginEntries.length === 1 ? '' : 's'} · all sourced`;
---

<BaseLayout
  title="§ 4 Plugins"
  description="Independent field notes on OpenClaw skills, MCP servers, and channel connectors. Lighter than formal scorecards. Each declares what we checked, what we didn't, sources used, and a dispute link."
  noIndex={true}
>
  <SectionHead num="4" title="Plugins" verb={verbCount} />
  <SectionBlurb>
    Independent <strong>field notes</strong>, not formal scorecards. Each entry declares what we
    checked, what we didn't, sources used, and a dispute link for the maintainer. We're not
    affiliated with any plugin author unless explicitly stated. Lighter editorial stance than a
    "verdict bands" review — more like research notes you can act on. See <a href="/methodology/">methodology</a>
    for how field notes work.
  </SectionBlurb>
  <CatalogTable entries={catalogEntries} />
</BaseLayout>
