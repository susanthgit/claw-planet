---
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionHero from '@components/SectionHero.astro';
import CatalogTable from '@components/CatalogTable.astro';
import { getCollection } from 'astro:content';

const allCompares = await getCollection('compares');
const compareEntries = allCompares
  .filter(e => e.data.section === 'Compare' && e.data.status === 'published')
  .sort((a, b) => a.data.sectionNumber.localeCompare(b.data.sectionNumber));

const catalogEntries = compareEntries.map(e => ({
  num: e.data.sectionNumber,
  title: e.data.title,
  href: `/compare/${e.id.replace(/\.mdx?$/, '')}/`,
  description: e.data.description,
  state: e.data.verificationState,
  date: e.data.lastReviewedAt,
}));

const tested = compareEntries.filter(e => e.data.verificationState.startsWith('tested')).length;
const sourced = compareEntries.filter(e => e.data.verificationState === 'sourced-only').length;
const planned = compareEntries.filter(e => e.data.verificationState === 'planned').length;

const lede = `OpenClaw vs the alternatives. Same axes per matchup — capability, cost, lock-in, maturity, where it leads, where it lags. Currently one deep matchup live (vs MCP-based stacks); more matchups (vs Claude Code, vs LangChain) ship as Sush gains direct experience comparing.`;
---

<BaseLayout
  title="§ 7 Compare"
  description="OpenClaw compared to its neighbours — MCP-based stacks, Claude Code, framework approaches. Where each wins, where each loses, when to switch."
>
  <SectionHero num="7" title="Compare" lede={lede} tested={tested} sourced={sourced} planned={planned} />
  <CatalogTable entries={catalogEntries} />
</BaseLayout>

