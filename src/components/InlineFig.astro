---
/**
 * InlineFig — small theme-aware architecture diagram.
 *
 * The grid pattern, layer dividers, edges, nodes, and labels all use
 * CSS classes so the SVG switches with [data-theme="dark"].
 *
 * For Phase 1 we render a fixed OpenClaw runtime diagram. Future
 * versions can take props or slot custom SVG.
 */

export interface Props {
  caption?: string;
}

const { caption = 'FIG. 1 · OpenClaw runtime — high-level flow' } = Astro.props;
---

<div class="inline-fig">
  <div class="inline-fig-cap">{caption}</div>
  <svg width="100%" viewBox="0 0 760 200" xmlns="http://www.w3.org/2000/svg" style="height: auto;">
    <style>
      .fig-grid path { stroke: var(--rule-faint); }
      .fig-layer { stroke: var(--rule); }
      .fig-edge { stroke: var(--ink-faint); }
      .fig-node { fill: var(--canvas); stroke: var(--ink); }
      .fig-node-text { fill: var(--ink); font-family: Inter, sans-serif; font-weight: 600; }
      .fig-agent { fill: var(--claw); stroke: var(--claw); }
      .fig-agent-text { fill: #FFFFFF; font-family: Inter, sans-serif; font-weight: 700; }
      .fig-label { fill: var(--ink-faint); font-family: 'JetBrains Mono', monospace; }
    </style>
    <defs>
      <pattern id="fig-grid-pattern" width="20" height="20" patternUnits="userSpaceOnUse" class="fig-grid">
        <path d="M 20 0 L 0 0 0 20" fill="none" stroke-width="0.4"/>
      </pattern>
    </defs>
    <rect width="760" height="200" fill="url(#fig-grid-pattern)" />

    <g stroke-width="0.5" stroke-dasharray="2 4" fill="none">
      <line class="fig-layer" x1="0" y1="50" x2="760" y2="50" />
      <line class="fig-layer" x1="0" y1="100" x2="760" y2="100" />
      <line class="fig-layer" x1="0" y1="150" x2="760" y2="150" />
    </g>

    <g stroke-width="0.9" fill="none">
      <line class="fig-edge" x1="120" y1="40" x2="380" y2="80" />
      <line class="fig-edge" x1="380" y1="80" x2="640" y2="40" />
      <line class="fig-edge" x1="380" y1="120" x2="380" y2="80" />
      <line class="fig-edge" x1="380" y1="120" x2="120" y2="160" />
      <line class="fig-edge" x1="380" y1="120" x2="640" y2="160" />
    </g>

    <g>
      <rect class="fig-node" x="80" y="20" width="80" height="40" stroke-width="1.2" />
      <text class="fig-node-text" x="120" y="44" text-anchor="middle" font-size="12">Slack</text>

      <rect class="fig-node" x="600" y="20" width="80" height="40" stroke-width="1.2" />
      <text class="fig-node-text" x="640" y="44" text-anchor="middle" font-size="12">WhatsApp</text>

      <rect class="fig-agent" x="320" y="60" width="120" height="40" stroke-width="1.2" />
      <text class="fig-agent-text" x="380" y="84" text-anchor="middle" font-size="13">OpenClaw agent</text>

      <rect class="fig-node" x="320" y="120" width="120" height="36" stroke-width="1.2" />
      <text class="fig-node-text" x="380" y="143" text-anchor="middle" font-size="12">Claude / GPT</text>

      <rect class="fig-node" x="80" y="140" width="80" height="36" stroke-width="1.2" />
      <text class="fig-node-text" x="120" y="163" text-anchor="middle" font-size="12">Browser</text>

      <rect class="fig-node" x="600" y="140" width="80" height="36" stroke-width="1.2" />
      <text class="fig-node-text" x="640" y="163" text-anchor="middle" font-size="12">Vector DB</text>
    </g>

    <g font-size="9">
      <text class="fig-label" x="8" y="44">channels</text>
      <text class="fig-label" x="8" y="84">runtime</text>
      <text class="fig-label" x="8" y="143">model</text>
      <text class="fig-label" x="8" y="163">i/o</text>
    </g>
  </svg>
</div>

<style>
  .inline-fig {
    margin: 24px 0;
    padding: 16px;
    background: var(--canvas);
    border: 1px solid var(--rule-faint);
  }
  .inline-fig-cap {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--ink-faint);
    letter-spacing: var(--ls-wider);
    margin-bottom: 10px;
    text-transform: uppercase;
  }
  .inline-fig svg { display: block; max-width: 100%; }
</style>
