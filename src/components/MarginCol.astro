---
/**
 * MarginCol — persistent right column.
 * Verification states (legend, FIRST per design) +
 * On this page (jump anchors — auto-derived per entry when tocItems prop is provided) +
 * Recently changed +
 * External links +
 * Sister site
 */

export interface TocItem {
  id: string;
  text: string;
  level: number;
}
export interface Props {
  tocItems?: TocItem[];
  recentlyChanged?: { title: string; meta: string; href: string }[];
}

const defaultGlobal = [
  { num: '§1', title: 'Overview', href: '#sec-1' },
  { num: '§2', title: 'Setup', href: '#sec-2' },
  { num: '§3', title: 'Connections', href: '#sec-3' },
  { num: '§4', title: 'Plugins', href: '#sec-4' },
  { num: '§5', title: 'Use cases', href: '#sec-5' },
  { num: '§6', title: 'Security', href: '#sec-6' },
  { num: '§7', title: 'Compare', href: '#sec-7' },
  { num: '§8', title: 'Updates', href: '#sec-8' },
  { num: '§9', title: 'Resources', href: '#sec-9' },
  { num: '§10', title: 'FAQ', href: '#sec-10' },
];

const {
  tocItems,
  recentlyChanged = [
    { title: '§4.1 Filesystem MCP', meta: '2026-05-07 · field note', href: '/openclaw/plugins/filesystem-mcp/' },
    { title: '§2.3 Laptop quick-start', meta: '2026-05-06 · WSL2 path verified', href: '/openclaw/setup/laptop/' },
    { title: '§8 Updates', meta: '2026-05-04 · easywebsearch advisory', href: '/updates/' },
  ],
} = Astro.props;

const useToc = Array.isArray(tocItems) && tocItems.length > 0;
---

<aside class="margin-col">
  <div class="margin-card">
    <h5>Verification states</h5>
    <div class="legend">
      <span><i style="background: var(--olive)"></i>tested by us</span>
      <span><i style="background: var(--amber)"></i>sourced only</span>
      <span><i style="background: var(--claw)"></i>planned · in progress</span>
    </div>
  </div>

  <div class="margin-card">
    <h5>On this page</h5>
    {useToc ? (
      <nav class="toc" aria-label="On this page">
        {tocItems!.map(item => (
          <a href={`#${item.id}`} class={`toc-${item.level}`} data-toc-target={item.id}>
            {item.text}
          </a>
        ))}
      </nav>
    ) : (
      defaultGlobal.map(item => (
        <a href={item.href}>{item.num} {item.title}</a>
      ))
    )}
  </div>

  <div class="margin-card">
    <h5>Recently changed</h5>
    {recentlyChanged.map(item => (
      <a href={item.href}>{item.title}<small>{item.meta}</small></a>
    ))}
  </div>

  <div class="margin-card">
    <h5>External</h5>
    <a href="https://openclaw.dev" target="_blank" rel="noopener">openclaw.dev (official docs)<small>↗ openclaw.dev</small></a>
    <a href="https://github.com/openclaw/awesome-openclaw" target="_blank" rel="noopener">Awesome OpenClaw<small>↗ github.com</small></a>
    <a href="https://discord.gg/clawd" target="_blank" rel="noopener">OpenClaw Discord<small>↗ discord.gg</small></a>
  </div>

  <div class="margin-card">
    <h5>Sister site</h5>
    <a href="https://agents.aguidetocloud.com" target="_blank" rel="noopener">Agentic Planet<small>agents.aguidetocloud.com</small></a>
  </div>
</aside>

{useToc && (
  <script is:inline>
    /* TOC active-on-scroll. Highlights the heading nearest the top of the viewport. */
    (function () {
      const links = Array.from(document.querySelectorAll('.toc a[data-toc-target]'));
      if (links.length === 0) return;
      const ids = links.map(l => l.getAttribute('data-toc-target')).filter(Boolean);
      const targets = ids.map(id => document.getElementById(id)).filter(Boolean);
      if (targets.length === 0) return;

      function setActive(id) {
        for (const a of links) {
          if (a.getAttribute('data-toc-target') === id) a.classList.add('active');
          else a.classList.remove('active');
        }
      }
      function onScroll() {
        let activeId = ids[0];
        for (const t of targets) {
          const r = t.getBoundingClientRect();
          if (r.top < 100) activeId = t.id;
        }
        setActive(activeId);
      }
      onScroll();
      window.addEventListener('scroll', onScroll, { passive: true });
    })();
  </script>
)}

<style>
  .margin-col {
    position: sticky;
    top: var(--header-h);
    align-self: start;
    height: calc(100vh - var(--header-h));
    overflow-y: auto;
    padding: 28px 0 32px;
    font-size: 12.5px;
    scrollbar-width: thin;
    scrollbar-color: var(--rule) transparent;
  }
  .margin-col::-webkit-scrollbar { width: 6px; }
  .margin-col::-webkit-scrollbar-thumb { background: var(--rule); border-radius: 3px; }

  .margin-card {
    border-top: 1px solid var(--rule-faint);
    padding: 18px 0;
  }
  .margin-card:first-child { border-top: 0; padding-top: 0; }

  .margin-card h5 {
    font-family: var(--mono);
    font-size: 9.5px;
    color: var(--ink-faint);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    font-weight: 700;
    margin-bottom: 10px;
  }
  .margin-card a {
    display: block;
    color: var(--ink-mid);
    text-decoration: none;
    font-size: 12.5px;
    padding: 4px 0;
    line-height: 1.4;
  }
  .margin-card a:hover { color: var(--claw); }
  .margin-card a small {
    display: block;
    font-family: var(--mono);
    font-size: 10px;
    color: var(--ink-faint);
    margin-top: 1px;
  }

  .margin-card .legend {
    display: flex; flex-direction: column; gap: 6px;
    font-family: var(--mono);
    font-size: 10.5px;
  }
  .margin-card .legend span {
    display: flex; align-items: center; gap: 8px;
    color: var(--ink-mute);
  }
  .margin-card .legend i {
    width: 8px; height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* In-page TOC (per-entry) */
  .toc { display: flex; flex-direction: column; }
  .toc a {
    border-left: 2px solid transparent;
    padding-left: 10px;
    margin-left: -2px;
    transition: border-color var(--dur-base) var(--ease), color var(--dur-base) var(--ease);
  }
  .toc a.toc-3 { padding-left: 22px; font-size: 12px; color: var(--ink-mute); }
  .toc a.active {
    color: var(--claw);
    border-left-color: var(--claw);
    font-weight: 500;
  }
</style>
