---
/**
 * FieldNote — full plugin field-note card with verification badge,
 * canonical reference, summary, structured properties, sources,
 * dispute link.
 *
 * Used on /openclaw/plugins/<slug>/ pages and as featured example on home.
 */

export interface Prop {
  label: string;
  value: string;
  tone?: 'warn' | 'ok' | 'mono';
}

export interface Props {
  num: string;             /* e.g. "4.1" */
  category: string;        /* e.g. "CHANNEL CONNECTOR" */
  canonicalRef: string;    /* e.g. "claw.connector.slack@2.4.1" */
  name: string;
  subtitle?: string;
  summary: string;
  state: 'planned' | 'sourced' | 'tried' | 'verified' | 'disputed';
  stateDate?: string;
  testedBy?: 'sush' | 'contributor';
  props: Prop[];
  disputeUrl?: string;
}

const {
  num,
  category,
  canonicalRef,
  name,
  subtitle,
  summary,
  state,
  stateDate,
  testedBy,
  props,
  disputeUrl = 'https://github.com/susanthgit/claw-planet/issues/new?template=dispute.md',
} = Astro.props;

function stateLabel(s: string, d?: string, by?: string): string {
  const map: Record<string, string> = {
    'tried': by === 'contributor' ? 'TRIED BY CONTRIBUTOR' : 'TRIED BY US',
    'verified': 'VERIFIED',
    'sourced': 'SOURCED',
    'disputed': 'DISPUTED',
    'planned': 'PLANNED',
  };
  return d ? `● ${map[s]} · ${d}` : `● ${map[s]}`;
}

function stateClass(s: string): string {
  if (s === 'tried' || s === 'verified') return 'verif-t';
  if (s === 'sourced') return 'verif-s';
  return 'verif-e';
}
---

<article class="field-note">
  <div class="field-note-meta">
    <div class="field-note-id">
      FIELD NOTE · §{num} · {category} · <span>{canonicalRef}</span>
    </div>
    <div class={`field-note-verif ${stateClass(state)}`}>{stateLabel(state, stateDate)}</div>
  </div>
  <h3>{name}</h3>
  {subtitle && <div class="canonical">{subtitle}</div>}
  <p class="summary">{summary}</p>

  <dl class="props">
    {props.map(p => (
      <>
        <dt>{p.label}</dt>
        <dd class={p.tone ?? ''}>
          {p.tone === 'mono' ? <span class="mono">{p.value}</span> : p.value}
        </dd>
      </>
    ))}
  </dl>

  <div class="field-note-foot">
    <span>Independent field note · not a certification.</span>
    <a href={disputeUrl} target="_blank" rel="noopener">Dispute or correct this entry →</a>
  </div>
</article>

<style>
  .field-note {
    border: 1px solid var(--rule);
    border-left: 3px solid var(--claw);
    background: var(--canvas);
    padding: 22px 26px;
    margin: 16px 0;
  }
  .field-note-meta {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 8px;
    flex-wrap: wrap;
    gap: 12px;
  }
  .field-note-id {
    font-family: var(--mono);
    font-size: 10.5px;
    color: var(--ink-faint);
    letter-spacing: var(--ls-wider);
  }
  .field-note-id span { color: var(--claw); }

  .field-note-verif {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: var(--ls-wide);
    padding: 2px 8px;
    border-radius: var(--radius-pill);
    border-width: 1px;
    border-style: solid;
  }
  .field-note-verif.verif-t {
    color: var(--olive); border-color: var(--olive); background: var(--olive-soft);
  }
  .field-note-verif.verif-s {
    color: var(--amber); border-color: var(--amber); background: var(--amber-soft);
  }
  .field-note-verif.verif-e {
    color: var(--claw); border-color: var(--claw); background: var(--claw-tint);
  }

  .field-note h3 {
    font-size: var(--fs-lg);
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: 4px;
    color: var(--ink);
  }
  .canonical {
    font-family: var(--mono);
    font-size: 11.5px;
    color: var(--ink-mute);
    margin-bottom: 14px;
  }
  .summary {
    font-size: 14.5px;
    line-height: var(--lh-normal);
    color: var(--ink);
    margin-bottom: 16px;
    max-width: 700px;
  }

  .props {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 6px 16px;
    border-top: 1px solid var(--rule-faint);
    padding-top: 14px;
    font-size: 13px;
  }
  .props dt {
    font-family: var(--mono);
    font-size: 10.5px;
    color: var(--ink-faint);
    text-transform: uppercase;
    letter-spacing: var(--ls-wider);
    padding-top: 1px;
  }
  .props dd { color: var(--ink); }
  .props dd.warn { color: var(--amber); }
  .props dd.ok { color: var(--olive); }
  .props dd .mono { font-family: var(--mono); font-size: 12px; color: var(--ink-mute); }

  .field-note-foot {
    margin-top: 14px;
    padding-top: 12px;
    border-top: 1px solid var(--rule-faint);
    display: flex;
    justify-content: space-between;
    font-family: var(--mono);
    font-size: 10.5px;
    color: var(--ink-faint);
    letter-spacing: var(--ls-wide);
    flex-wrap: wrap;
    gap: 12px;
  }
  .field-note-foot a { color: var(--claw); text-decoration: underline; text-decoration-color: var(--claw); }
</style>
