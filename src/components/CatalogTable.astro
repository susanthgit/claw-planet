---
/**
 * CatalogTable — definition-list of section entries.
 * Used by §1, §2, §3, §5, §6, §7, §9, §10 catalogs.
 *
 * Each entry: number · title · description · verification pill · date.
 */

export interface Entry {
  num: string;
  title: string;
  href: string;
  description: string;
  ref?: string;
  state?: 'planned' | 'sourced' | 'tried' | 'verified' | 'disputed' | 'published' | 'trusted' | 'answered' | 'deep' | 'early' | 'live' | 'map-complete';
  pillLabel?: string;
  date?: string;
}

export interface Props {
  entries: Entry[];
}

const { entries } = Astro.props;

function pillClass(state?: string): string {
  if (!state) return '';
  if (['tried', 'verified', 'published', 'trusted', 'answered', 'deep', 'live', 'map-complete'].includes(state)) return 't';
  if (['sourced'].includes(state)) return 's';
  if (['planned', 'disputed', 'early'].includes(state)) return 'e';
  return '';
}

function pillText(state?: string, fallback?: string): string {
  if (fallback) return fallback;
  if (!state) return '';
  const map: Record<string, string> = {
    'tried': 'tried',
    'verified': 'verified',
    'sourced': 'sourced',
    'disputed': 'disputed',
    'planned': 'planned',
    'published': 'published',
    'trusted': 'trusted',
    'answered': 'answered',
    'deep': 'deep',
    'early': 'early',
    'live': 'live',
    'map-complete': 'map complete',
  };
  return map[state] ?? state;
}
---

<dl class="entries">
  {entries.map(entry => (
    <div class="entry">
      <span class="entry-num">{entry.num}</span>
      <div>
        <div class="entry-title">
          <a href={entry.href} set:html={entry.title}></a>
          {entry.ref && <span class="ref" set:html={entry.ref}></span>}
        </div>
        <div class="entry-desc" set:html={entry.description}></div>
      </div>
      <span class="entry-verif">
        {entry.state && (
          <span class={`pill ${pillClass(entry.state)}`}>{pillText(entry.state, entry.pillLabel)}</span>
        )}
      </span>
      {entry.date && <span class="entry-date">{entry.date}</span>}
    </div>
  ))}
</dl>

<style>
  dl.entries {
    border-top: 1px solid var(--rule-faint);
  }
  dl.entries .entry {
    display: grid;
    grid-template-columns: 56px 1fr 160px 100px;
    gap: 20px;
    padding: 14px 4px;
    border-bottom: 1px solid var(--rule-faint);
    align-items: baseline;
    transition: background var(--dur-fast) var(--ease);
  }
  dl.entries .entry:hover { background: var(--paper-warm); }

  .entry-num {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--ink-faint);
    letter-spacing: var(--ls-wide);
  }
  .entry-title {
    font-weight: 600;
    color: var(--ink);
    font-size: 14.5px;
  }
  .entry-title a {
    color: inherit;
    text-decoration: none;
  }
  .entry-title a:hover { color: var(--claw); }
  .entry-title .ref {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--ink-faint);
    margin-left: 8px;
    font-weight: 400;
  }
  .entry-desc {
    color: var(--ink-mute);
    font-size: 13.5px;
    margin-top: 3px;
    line-height: 1.55;
    max-width: 720px;
  }
  .entry-verif {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--ink-faint);
    letter-spacing: var(--ls-wide);
  }
  .entry-verif .pill {
    display: inline-block;
    padding: 2px 8px;
    border: 1px solid var(--rule);
    background: var(--paper-warm);
    border-radius: var(--radius-pill);
    color: var(--ink-mute);
  }
  .entry-verif .pill.t { color: var(--olive); border-color: var(--olive); background: var(--olive-soft); }
  .entry-verif .pill.s { color: var(--amber); border-color: var(--amber); background: var(--amber-soft); }
  .entry-verif .pill.e { color: var(--claw); border-color: var(--claw); background: var(--claw-tint); }
  .entry-date {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--ink-faint);
    text-align: right;
  }

  /* Responsive — collapse columns at narrow viewport */
  @media (max-width: 1080px) {
    dl.entries .entry { grid-template-columns: 40px 1fr 120px; }
    .entry-date { display: none; }
  }
  @media (max-width: 720px) {
    dl.entries .entry { grid-template-columns: 1fr; gap: 6px; }
    .entry-num, .entry-verif { font-size: 10px; }
  }
</style>
