---
/**
 * SearchModal — Pagefind-powered static search.
 * Triggered by ⌘K (Ctrl+K), '/', or click on the header search bar.
 * Loads pagefind-ui lazily on first open.
 */
---

<div id="cp-search-modal" class="search-modal" hidden role="dialog" aria-modal="true" aria-label="Search the reference">
  <button class="search-backdrop" id="cp-search-backdrop" aria-label="Close search"></button>
  <div class="search-panel">
    <div class="search-panel-head">
      <span class="search-panel-title">Search the reference</span>
      <button class="search-close" id="cp-search-close" aria-label="Close">esc</button>
    </div>
    <div id="cp-pagefind-mount" class="search-mount"></div>
    <div class="search-foot">
      <span><kbd>↑</kbd> <kbd>↓</kbd> navigate</span>
      <span><kbd>enter</kbd> open</span>
      <span><kbd>esc</kbd> close</span>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    const modal = document.getElementById('cp-search-modal');
    const trigger = document.getElementById('cp-search-trigger');
    const backdrop = document.getElementById('cp-search-backdrop');
    const closeBtn = document.getElementById('cp-search-close');
    const mount = document.getElementById('cp-pagefind-mount');
    if (!modal || !mount) return;

    let uiLoaded = false;
    let pagefindUI = null;
    let inputEl = null;

    async function ensureLoaded() {
      if (uiLoaded) return;
      uiLoaded = true;
      try {
        // Pagefind builds an `_pagefind/pagefind-ui.js` ESM bundle into dist
        const css = document.createElement('link');
        css.rel = 'stylesheet';
        css.href = '/_pagefind/pagefind-ui.css';
        document.head.appendChild(css);
        const mod = await import('/_pagefind/pagefind-ui.js');
        pagefindUI = new mod.PagefindUI({
          element: mount,
          showImages: false,
          showSubResults: true,
          resetStyles: false,
          baseUrl: '/',
          translations: {
            placeholder: 'Search concepts, plugins, setup, gotchas...',
            zero_results: 'No matches. Try fewer terms or different words.',
          },
        });
      } catch (e) {
        // Fallback if pagefind hasn't been built yet (dev mode)
        mount.innerHTML = '<p class="search-fallback">Search index unavailable in dev. Run a full <code>npm run build</code> to generate it.</p>';
      }
      // After load, locate the input and focus it
      requestAnimationFrame(() => {
        inputEl = mount.querySelector('input[type="text"], input[type="search"], .pagefind-ui__search-input');
        if (inputEl) inputEl.focus();
      });
    }

    function open() {
      modal.hidden = false;
      modal.classList.add('open');
      document.body.style.overflow = 'hidden';
      ensureLoaded().then(() => {
        const el = mount.querySelector('input[type="text"], input[type="search"], .pagefind-ui__search-input');
        if (el) el.focus();
      });
    }
    function close() {
      modal.hidden = true;
      modal.classList.remove('open');
      document.body.style.overflow = '';
      if (trigger && trigger.blur) trigger.blur();
    }

    function isInput(target) {
      const tag = target.tagName;
      return tag === 'INPUT' || tag === 'TEXTAREA' || target.isContentEditable;
    }

    document.addEventListener('keydown', (e) => {
      // ⌘K / Ctrl+K opens search regardless
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        modal.hidden ? open() : close();
        return;
      }
      // ESC closes
      if (e.key === 'Escape' && !modal.hidden) {
        e.preventDefault();
        close();
        return;
      }
      // '/' opens (when not already in an input)
      if (e.key === '/' && !isInput(e.target) && modal.hidden) {
        e.preventDefault();
        open();
      }
    });

    if (trigger) trigger.addEventListener('click', (e) => { e.preventDefault(); open(); });
    if (trigger) trigger.addEventListener('focus', () => open());
    if (backdrop) backdrop.addEventListener('click', close);
    if (closeBtn) closeBtn.addEventListener('click', close);
  })();
</script>

<style>
  .search-modal {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 80px;
  }
  .search-modal[hidden] { display: none; }
  .search-backdrop {
    position: absolute;
    inset: 0;
    background: var(--ink);
    opacity: 0.45;
    border: 0;
    cursor: pointer;
    padding: 0;
  }
  :global([data-theme="dark"]) .search-backdrop { opacity: 0.65; }

  .search-panel {
    position: relative;
    width: min(680px, calc(100vw - 32px));
    max-height: calc(100vh - 160px);
    background: var(--paper);
    border: 1px solid var(--rule);
    box-shadow: 0 12px 60px rgba(0, 0, 0, 0.18);
    display: flex;
    flex-direction: column;
  }
  :global([data-theme="dark"]) .search-panel {
    box-shadow: 0 12px 60px rgba(0, 0, 0, 0.6);
  }
  .search-panel-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 18px;
    border-bottom: 1px solid var(--rule-faint);
  }
  .search-panel-title {
    font-family: var(--mono);
    font-size: 10.5px;
    color: var(--ink-faint);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    font-weight: 600;
  }
  .search-close {
    border: 1px solid var(--rule);
    background: var(--canvas);
    color: var(--ink-mute);
    font-family: var(--mono);
    font-size: 11px;
    padding: 4px 8px;
    cursor: pointer;
  }
  .search-close:hover { color: var(--claw); border-color: var(--claw); }
  .search-mount {
    padding: 16px;
    overflow-y: auto;
    flex: 1;
  }
  .search-foot {
    display: flex;
    gap: 16px;
    padding: 10px 16px;
    border-top: 1px solid var(--rule-faint);
    font-family: var(--mono);
    font-size: 10.5px;
    color: var(--ink-faint);
  }
  .search-foot kbd {
    background: var(--canvas);
    border: 1px solid var(--rule-faint);
    border-radius: 3px;
    padding: 1px 5px;
    font-family: var(--mono);
    font-size: 10px;
  }
  .search-fallback { color: var(--ink-mute); font-size: 13px; padding: 12px; }
  .search-fallback code { font-family: var(--mono); background: var(--paper-warm); padding: 1px 5px; }

  /* Pagefind UI overrides — match site visual language */
  .search-mount :global(.pagefind-ui) {
    --pagefind-ui-scale: 0.9;
    --pagefind-ui-primary: var(--claw);
    --pagefind-ui-text: var(--ink);
    --pagefind-ui-background: var(--paper);
    --pagefind-ui-border: var(--rule-faint);
    --pagefind-ui-tag: var(--paper-warm);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 0;
    --pagefind-ui-image-border-radius: 0;
    --pagefind-ui-image-box-ratio: 3 / 2;
    --pagefind-ui-font: var(--sans);
  }
  .search-mount :global(.pagefind-ui__search-input) {
    background: var(--canvas) !important;
    border-color: var(--rule) !important;
    font-family: var(--mono) !important;
  }
  .search-mount :global(.pagefind-ui__result-link) {
    color: var(--ink) !important;
    font-weight: 600 !important;
  }
  .search-mount :global(.pagefind-ui__result-link:hover) {
    color: var(--claw) !important;
  }
  .search-mount :global(mark) {
    background: var(--claw-tint) !important;
    color: var(--claw) !important;
  }
</style>
