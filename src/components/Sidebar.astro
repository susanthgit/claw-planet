---
/**
 * Sidebar — persistent left navigation.
 * Contents (§1–§10 with sub-items + verification badges) +
 * Reading aids (subordinate group at the bottom).
 *
 * Verification badge classes:
 *   .verif.t — tried / verified (olive)
 *   .verif.s — sourced (amber)
 *   .verif.e — planned / disputed (claw red)
 */
import { getCollection } from 'astro:content';
import coverage from '@data/coverage.json';

function badge(state: string | undefined): { state: 't' | 's' | 'e'; label: string } {
  if (state === 'tried' || state === 'verified') return { state: 't', label: state === 'verified' ? 'verified' : 'tried' };
  if (state === 'sourced') return { state: 's', label: 'sourced' };
  if (state === 'disputed') return { state: 'e', label: 'disputed' };
  if (state === 'planned') return { state: 'e', label: 'planned' };
  return { state: 's', label: 'sourced' };
}

async function loadChildren(name: string, baseHref: string) {
  const all = await getCollection(name as any);
  return all
    .filter((e: any) => e.data.status === 'published')
    .sort((a: any, b: any) => a.data.sectionNumber.localeCompare(b.data.sectionNumber))
    .map((e: any) => {
      const slug = e.id.replace(/\.mdx?$/, '');
      const b = badge(e.data.verificationState);
      return {
        num: e.data.sectionNumber,
        title: e.data.title,
        href: `${baseHref}${slug}/`,
        state: b.state,
        label: b.label,
      };
    });
}

const overviewKids = await loadChildren('explainers', '/overview/');
const setupKids = await loadChildren('setups', '/setup/');
const connectionsKids = await loadChildren('connections', '/connections/');
const pluginsKids = await loadChildren('plugins', '/plugins/');
const useCasesKids = await loadChildren('use-cases', '/use-cases/');
const securityKids = await loadChildren('gotchas', '/security/');
const compareKids = await loadChildren('compares', '/compare/');

const sections = [
  { num: '§1', title: 'Overview', count: overviewKids.length, slug: '/overview/', children: overviewKids },
  { num: '§2', title: 'Setup', count: setupKids.length, slug: '/setup/', children: setupKids },
  { num: '§3', title: 'Connections', count: connectionsKids.length, slug: '/connections/', children: connectionsKids },
  { num: '§4', title: 'Plugins', count: pluginsKids.length, slug: '/plugins/', children: pluginsKids },
  { num: '§5', title: 'Use cases', count: useCasesKids.length, slug: '/use-cases/', children: useCasesKids },
  { num: '§6', title: 'Security', count: securityKids.length, slug: '/security/', children: securityKids },
  { num: '§7', title: 'Compare', count: compareKids.length, slug: '/compare/', children: compareKids },
  { num: '§8', title: 'Updates', count: coverage.sections.updates.current, slug: '/updates/' },
  { num: '§9', title: 'Resources', count: coverage.sections.resources.current, slug: '/resources/' },
  { num: '§10', title: 'FAQ', count: coverage.sections.faq.current, slug: '/faq/' },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') + '/';

const readingAids = [
  { title: 'Methodology', slug: '/methodology/' },
  { title: 'Verification states', slug: '/methodology/#verification-states' },
  { title: 'Sources & citations', slug: '/methodology/#sources' },
  { title: 'Dispute an entry', slug: 'https://github.com/susanthgit/claw-planet/issues/new?template=dispute.md' },
  { title: 'llms.txt', slug: '/llms.txt' },
];
---

<aside class="sidebar">
  <h4>Contents</h4>

  {sections.map(sec => {
    const isCurrentSection = currentPath.startsWith(sec.slug);
    return (
    <div class={`nav-group ${isCurrentSection ? 'is-current-section' : ''}`}>
      <a class={`nav-section ${currentPath === sec.slug ? 'active' : ''}`} href={sec.slug} aria-current={currentPath === sec.slug ? 'page' : undefined}>
        <span class="num">{sec.num}</span>{sec.title}
        {sec.count !== undefined && <span class="count">{sec.count}</span>}
      </a>
      {sec.children && sec.children.length > 0 && (
        <ul class="nav-children">
          {sec.children.map((child: any) => (
            <li>
              <a href={child.href} class={currentPath === child.href ? 'active' : ''} aria-current={currentPath === child.href ? 'page' : undefined}>
                {child.num}  {child.title}
                {child.state && child.label && <span class={`verif ${child.state}`}>{child.label}</span>}
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
    );
  })}

  <h4 class="nav-aside-head">Reading aids</h4>
  {readingAids.map(aid => (
    <a class="nav-aside" href={aid.slug}>{aid.title}</a>
  ))}
</aside>

<style>
  .sidebar {
    position: sticky;
    top: var(--header-h);
    align-self: start;
    height: calc(100vh - var(--header-h));
    overflow-y: auto;
    padding: 24px 0 32px;
    border-right: 1px solid var(--rule-faint);
    padding-right: 16px;
    margin-right: -8px;
    font-size: 13px;
    scrollbar-width: thin;
    scrollbar-color: var(--rule) transparent;
  }
  .sidebar::-webkit-scrollbar { width: 6px; }
  .sidebar::-webkit-scrollbar-thumb { background: var(--rule); border-radius: 3px; }

  .sidebar h4 {
    font-family: var(--mono);
    font-size: 9.5px;
    font-weight: 700;
    color: var(--ink-faint);
    text-transform: uppercase;
    letter-spacing: var(--ls-widest);
    margin: 22px 0 8px;
    padding-bottom: 4px;
    border-bottom: 1px dashed var(--rule-faint);
  }
  .sidebar h4:first-child { margin-top: 0; }

  .nav-group { margin-bottom: 4px; }
  .nav-section {
    display: block;
    padding: 4px 0;
    text-decoration: none;
    color: var(--ink);
    font-weight: 600;
    font-size: 13.5px;
    letter-spacing: -0.005em;
  }
  .nav-section:hover { color: var(--claw); }
  .nav-section .num {
    font-family: var(--mono);
    color: var(--ink-faint);
    font-weight: 500;
    font-size: 11px;
    margin-right: 8px;
  }
  .nav-section .count {
    font-family: var(--mono);
    color: var(--ink-faint);
    font-weight: 400;
    font-size: 10px;
    margin-left: 6px;
  }
  .nav-children {
    margin: 4px 0 8px 28px;
    list-style: none;
  }
  .nav-children li { padding: 2px 0; }
  .nav-children a {
    color: var(--ink-mute);
    text-decoration: none;
    font-size: 12.5px;
    font-weight: 400;
    display: flex;
    justify-content: space-between;
    gap: 8px;
  }
  .nav-children a:hover { color: var(--claw); }
  .nav-children a.active {
    color: var(--claw);
    font-weight: 500;
  }
  .nav-section.active {
    color: var(--claw);
  }
  .is-current-section .nav-section {
    color: var(--ink);
  }
  .nav-children a .verif {
    font-family: var(--mono);
    font-size: 9px;
    padding: 1px 5px;
    border-radius: var(--radius-sm);
    flex-shrink: 0;
    color: var(--ink-faint);
    background: var(--paper-warm);
    border: 1px solid var(--rule-faint);
    letter-spacing: var(--ls-wide);
  }
  .nav-children a .verif.t { color: var(--olive); border-color: var(--olive); background: var(--olive-soft); }
  .nav-children a .verif.s { color: var(--amber); border-color: var(--amber); background: var(--amber-soft); }
  .nav-children a .verif.e { color: var(--claw); border-color: var(--claw); background: var(--claw-tint); }

  .nav-aside-head {
    font-family: var(--mono);
    font-size: 9px;
    font-weight: 500;
    color: var(--ink-faint);
    text-transform: uppercase;
    letter-spacing: var(--ls-widest);
    margin: 28px 0 6px;
    padding-bottom: 0;
    border-bottom: 0;
    opacity: 0.75;
  }
  .nav-aside {
    display: block;
    padding: 2px 0 2px 14px;
    text-decoration: none;
    color: var(--ink-mute);
    font-size: 12px;
    font-weight: 400;
    position: relative;
  }
  .nav-aside::before {
    content: '·';
    position: absolute;
    left: 4px;
    color: var(--ink-faint);
  }
  .nav-aside:hover { color: var(--claw); }
</style>
