---
/**
 * GlobalEnhance — runtime enhancements that apply to every page.
 * - Code copy buttons on every <pre>
 * - Keyboard shortcuts: j/k = prev/next, gg = home, ? = help
 *
 * Loaded by BaseLayout, runs after DOMContentLoaded.
 */
---

<div id="cp-help-modal" class="help-modal" hidden role="dialog" aria-modal="true" aria-label="Keyboard shortcuts">
  <button class="help-backdrop" id="cp-help-backdrop" aria-label="Close help"></button>
  <div class="help-panel">
    <div class="help-head">
      <span class="help-title">Keyboard shortcuts</span>
      <button class="help-close" id="cp-help-close" aria-label="Close">esc</button>
    </div>
    <table class="help-table">
      <tr><td><kbd>⌘</kbd> + <kbd>K</kbd> · <kbd>/</kbd></td><td>open search</td></tr>
      <tr><td><kbd>j</kbd></td><td>next entry (within section)</td></tr>
      <tr><td><kbd>k</kbd></td><td>previous entry</td></tr>
      <tr><td><kbd>g</kbd> <kbd>h</kbd></td><td>go to home</td></tr>
      <tr><td><kbd>g</kbd> <kbd>m</kbd></td><td>go to methodology</td></tr>
      <tr><td><kbd>?</kbd></td><td>show this help</td></tr>
      <tr><td><kbd>esc</kbd></td><td>close any modal</td></tr>
    </table>
  </div>
</div>

<script is:inline>
  (function () {
    function isInput(target) {
      const tag = target.tagName;
      return tag === 'INPUT' || tag === 'TEXTAREA' || target.isContentEditable;
    }

    /* === code copy buttons === */
    function addCopyButtons() {
      const blocks = document.querySelectorAll('.prose pre');
      blocks.forEach((pre) => {
        if (pre.querySelector('.cp-copy-btn')) return;
        const btn = document.createElement('button');
        btn.className = 'cp-copy-btn';
        btn.type = 'button';
        btn.setAttribute('aria-label', 'Copy code');
        btn.textContent = 'copy';
        pre.appendChild(btn);
        btn.addEventListener('click', async () => {
          const code = pre.querySelector('code');
          const text = code ? code.innerText : pre.innerText;
          try {
            await navigator.clipboard.writeText(text);
            btn.textContent = 'copied';
            btn.classList.add('copied');
            setTimeout(() => { btn.textContent = 'copy'; btn.classList.remove('copied'); }, 1500);
          } catch (e) {
            btn.textContent = 'failed';
            setTimeout(() => { btn.textContent = 'copy'; }, 1500);
          }
        });
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', addCopyButtons);
    } else {
      addCopyButtons();
    }

    /* === keyboard shortcuts === */
    const helpModal = document.getElementById('cp-help-modal');
    const helpBackdrop = document.getElementById('cp-help-backdrop');
    const helpClose = document.getElementById('cp-help-close');

    function showHelp() {
      if (!helpModal) return;
      helpModal.hidden = false;
      helpModal.classList.add('open');
      document.body.style.overflow = 'hidden';
    }
    function hideHelp() {
      if (!helpModal) return;
      helpModal.hidden = true;
      helpModal.classList.remove('open');
      document.body.style.overflow = '';
    }
    if (helpBackdrop) helpBackdrop.addEventListener('click', hideHelp);
    if (helpClose) helpClose.addEventListener('click', hideHelp);

    let lastG = 0;
    document.addEventListener('keydown', (e) => {
      if (isInput(e.target)) return;
      // ? = help
      if (e.key === '?') {
        e.preventDefault();
        showHelp();
        return;
      }
      // esc closes help (search modal handles its own esc)
      if (e.key === 'Escape' && helpModal && !helpModal.hidden) {
        e.preventDefault();
        hideHelp();
        return;
      }
      // g + letter
      if (e.key === 'g') {
        lastG = Date.now();
        return;
      }
      if (Date.now() - lastG < 1000) {
        if (e.key === 'h') { e.preventDefault(); window.location.href = '/'; return; }
        if (e.key === 'm') { e.preventDefault(); window.location.href = '/methodology/'; return; }
        if (e.key === 's') { e.preventDefault(); window.location.href = '/openclaw/setup/'; return; }
        if (e.key === 'o') { e.preventDefault(); window.location.href = '/openclaw/overview/'; return; }
      }
      // j = next, k = prev (read from EntryFooter prev/next links)
      if (e.key === 'j' || e.key === 'k') {
        const sel = e.key === 'j' ? '.pn-next a' : '.pn-prev a';
        const link = document.querySelector(sel);
        if (link && link.href) { e.preventDefault(); window.location.href = link.href; }
      }
    });

    /* === inline glossary tooltips === */
    const GLOSSARY = {
      'Gateway': { url: '/openclaw/overview/concepts/#gateway', def: 'The persistent OpenClaw daemon that runs on your machine — handles channel webhooks, sessions, and plugin loading. One per box.' },
      'agent runtime': { url: '/openclaw/overview/concepts/#agent-runtime', def: 'The single agent process inside the Gateway. Built on the Pi agent core (models, tools, prompt pipeline).' },
      'workspace': { url: '/openclaw/overview/concepts/#workspace', def: 'The directory of plain markdown files that defines the agent — SOUL.md, AGENTS.md, USER.md, and so on.' },
      'channels': { url: '/openclaw/overview/concepts/#channels', def: 'Where messages come from and go to — 24+ supported (Slack, WhatsApp, iMessage, Discord, Telegram, etc.).' },
      'channel': { url: '/openclaw/overview/concepts/#channels', def: 'Where messages come from and go to — 24+ supported (Slack, WhatsApp, iMessage, Discord, Telegram, etc.).' },
      'tools': { url: '/openclaw/overview/concepts/#tools', def: 'Capabilities the agent can call — built-ins (read_file, http_request), skills, or MCP servers.' },
      'skills': { url: '/openclaw/overview/concepts/#skill', def: 'OpenClaw plugins that add tools. Live inside the workspace.' },
      'skill': { url: '/openclaw/overview/concepts/#skill', def: 'An OpenClaw plugin that adds a tool. Lives inside the workspace.' },
      'MCP': { url: '/openclaw/overview/concepts/#mcp', def: "Model Context Protocol — Anthropic's open standard for connecting agents to external tools/data. OpenClaw consumes MCP servers via its mcp bridge." },
      'plugin': { url: '/openclaw/overview/concepts/#plugin', def: 'A package added to OpenClaw — channel adapter, skill, memory engine, model provider, etc.' },
      'plugins': { url: '/openclaw/overview/concepts/#plugin', def: 'Packages added to OpenClaw — channel adapters, skills, memory engines, model providers, etc.' },
    };

    function shouldSkipNode(node) {
      let p = node.parentElement;
      while (p) {
        const tag = p.tagName;
        if (tag === 'A' || tag === 'CODE' || tag === 'PRE' || tag === 'KBD' ||
            tag === 'H1' || tag === 'H2' || tag === 'H3' || tag === 'H4' ||
            p.classList.contains('cp-tooltip') || p.classList.contains('cp-no-tooltip')) {
          return true;
        }
        if (p.classList.contains('prose')) return false; // inside prose
        p = p.parentElement;
      }
      return true; // not inside .prose
    }

    function wrapGlossary() {
      const prose = document.querySelector('.prose');
      if (!prose) return;
      const seen = new Set();
      const terms = Object.keys(GLOSSARY).sort((a, b) => b.length - a.length); // longest first
      for (const term of terms) {
        if (seen.has(term)) continue;
        // build a regex for whole-word match
        const re = new RegExp('(\\b)(' + term.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')(\\b)');
        const walker = document.createTreeWalker(prose, NodeFilter.SHOW_TEXT, {
          acceptNode: (n) => {
            if (shouldSkipNode(n)) return NodeFilter.FILTER_REJECT;
            if (re.test(n.textContent)) return NodeFilter.FILTER_ACCEPT;
            return NodeFilter.FILTER_SKIP;
          },
        });
        const target = walker.nextNode();
        if (!target) continue;
        const text = target.textContent;
        const m = re.exec(text);
        if (!m) continue;
        const before = text.slice(0, m.index + m[1].length);
        const matched = m[2];
        const after = text.slice(m.index + m[1].length + m[2].length);
        const span = document.createElement('span');
        span.className = 'cp-tooltip';
        span.tabIndex = 0;
        span.textContent = matched;
        const def = GLOSSARY[term].def;
        const url = GLOSSARY[term].url;
        const tip = document.createElement('span');
        tip.className = 'cp-tooltip-pop';
        tip.innerHTML = `<strong>${matched}</strong><br>${def} <a href="${url}">(read more →)</a>`;
        span.appendChild(tip);
        const parent = target.parentNode;
        const beforeNode = document.createTextNode(before);
        const afterNode = document.createTextNode(after);
        parent.insertBefore(beforeNode, target);
        parent.insertBefore(span, target);
        parent.insertBefore(afterNode, target);
        parent.removeChild(target);
        seen.add(term);
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', wrapGlossary);
    } else {
      wrapGlossary();
    }
  })();
</script>

<style is:global>
  /* Code copy button */
  .prose pre {
    position: relative;
  }
  .cp-copy-btn {
    position: absolute;
    top: 6px;
    right: 6px;
    background: var(--paper-warm);
    border: 1px solid var(--rule);
    color: var(--ink-mute);
    font-family: var(--mono);
    font-size: 10px;
    padding: 2px 8px;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: var(--ls-wide);
    opacity: 0;
    transition: opacity var(--dur-base) var(--ease), color var(--dur-base) var(--ease), border-color var(--dur-base) var(--ease);
  }
  .prose pre:hover .cp-copy-btn,
  .cp-copy-btn:focus { opacity: 1; }
  .cp-copy-btn:hover { color: var(--claw); border-color: var(--claw); }
  .cp-copy-btn.copied { color: var(--olive); border-color: var(--olive); }

  /* Glossary tooltip */
  .cp-tooltip {
    position: relative;
    border-bottom: 1px dotted var(--ink-faint);
    cursor: help;
  }
  .cp-tooltip:hover { border-bottom-color: var(--claw); color: var(--claw); }
  .cp-tooltip-pop {
    position: absolute;
    bottom: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(-8px);
    width: 280px;
    padding: 10px 14px;
    background: var(--paper);
    border: 1px solid var(--rule);
    box-shadow: 0 6px 20px rgba(0,0,0,0.12);
    font-size: 12.5px;
    line-height: 1.5;
    color: var(--ink-mid);
    text-align: left;
    cursor: auto;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 120ms var(--ease), transform 120ms var(--ease);
    z-index: 50;
    font-style: normal;
    font-weight: 400;
  }
  :global([data-theme="dark"]) .cp-tooltip-pop {
    box-shadow: 0 6px 20px rgba(0,0,0,0.55);
  }
  .cp-tooltip-pop strong {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--claw);
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
    display: block;
    margin-bottom: 4px;
  }
  .cp-tooltip-pop a {
    color: var(--ink-mute);
    text-decoration: none;
    border-bottom: 1px solid var(--rule);
    font-size: 11.5px;
  }
  .cp-tooltip-pop a:hover { color: var(--claw); border-color: var(--claw); }
  .cp-tooltip:hover .cp-tooltip-pop,
  .cp-tooltip:focus .cp-tooltip-pop,
  .cp-tooltip:focus-within .cp-tooltip-pop {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(-4px);
    pointer-events: auto;
  }
  /* mobile: no hover, so click-to-focus is the path. Keep z-index above anything. */
  @media (max-width: 640px) {
    .cp-tooltip-pop { width: 240px; }
  }

  /* Help modal */
  .help-modal {
    position: fixed;
    inset: 0;
    z-index: 999;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .help-modal[hidden] { display: none; }
  .help-backdrop {
    position: absolute;
    inset: 0;
    background: var(--ink);
    opacity: 0.4;
    border: 0;
    cursor: pointer;
    padding: 0;
  }
  .help-panel {
    position: relative;
    width: min(420px, calc(100vw - 32px));
    background: var(--paper);
    border: 1px solid var(--rule);
    padding: 0 0 16px;
  }
  .help-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 18px;
    border-bottom: 1px solid var(--rule-faint);
  }
  .help-title {
    font-family: var(--mono);
    font-size: 10.5px;
    color: var(--ink-faint);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    font-weight: 600;
  }
  .help-close {
    border: 1px solid var(--rule);
    background: var(--canvas);
    color: var(--ink-mute);
    font-family: var(--mono);
    font-size: 11px;
    padding: 4px 8px;
    cursor: pointer;
  }
  .help-close:hover { color: var(--claw); border-color: var(--claw); }
  .help-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 8px;
  }
  .help-table td {
    padding: 6px 18px;
    font-size: 12.5px;
    color: var(--ink-mid);
  }
  .help-table td:first-child {
    font-family: var(--mono);
    color: var(--ink);
    width: 1%;
    white-space: nowrap;
  }
  .help-table kbd {
    display: inline-block;
    background: var(--canvas);
    border: 1px solid var(--rule-faint);
    border-radius: 3px;
    padding: 1px 5px;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--ink);
  }
</style>
